// Copy to secrets.h and fill in. secrets.h is gitignored.
//
// Everything here is either a credential or something that identifies this
// particular installation. Behavioural tuning -- poll intervals, which coin to
// track, the API paths -- lives in config.h, which is committed.
//
// The location and timezone values below, and the tracked coins/stocks in
// config.h, are now only the *factory defaults*: once Config Mode has written
// NVS (ADR-0005) the device reads those instead, and editing here changes only
// what a freshly flashed or NVS-erased device starts on. The Finnhub token is
// not editable on the device and still changes here and reflash.
//
// WiFi is now editable too, but through a different door than Config Mode:
// reaching the config server needs the radio already up, so WiFi cannot change
// the network it runs on. Instead, when the device cannot join the saved
// network -- or the screen is held during boot -- it stands up its own access
// point (WiFi Setup) and a phone provisions the real SSID and password into
// NVS. The values below are therefore only the factory defaults the very first
// boot tries; after WiFi Setup writes NVS, editing here changes nothing until a
// fresh flash or an NVS erase.
#pragma once

#define WIFI_SSID     "your-network"
#define WIFI_PASSWORD "your-password"

// The Mac running bridge/quota_bridge.py, without a trailing slash. An IP is
// more reliable than mDNS on networks with client isolation or a flaky .local
// resolver. Give the Mac a DHCP reservation so the address stays put.
//
// This is now only the factory default: Config Mode edits the bridge address on
// the device (validated by actually fetching /quota off it) and stores it in
// NVS, so a moved Mac is a portal edit, not a reflash. Editing here changes only
// what a freshly flashed or NVS-erased device starts on. host:port or a bare IP
// both work in the portal -- http:// and :8787 are filled in for you.
#define BRIDGE_BASE_URL "http://192.168.1.117:8787"

// Where the display is. Used only for the weather feed. Four decimal places is
// ~11m of precision, which is far more than the forecast resolution needs --
// rounding to two is plenty and leaks less if this file ever escapes.
#define WEATHER_LATITUDE  13.75f
#define WEATHER_LONGITUDE 100.50f

// Timezone for this installation. It lives here, next to the coordinates,
// because it describes where the display sits -- not repo-wide behaviour. Two
// values, because two consumers want different formats and the device has no tz
// database to convert one into the other; keep both describing the same place:
//
//   WEATHER_TZ -- IANA zone name, sent to Open-Meteo so the forecast's fields
//                 land on this zone's local time rather than UTC. City names
//                 only -- Open-Meteo does not take a bare offset.
//   CLOCK_TZ   -- offset from UTC for the header clock, written the way a person
//                 says it: "UTC+7", "UTC-5", "UTC+5:30", or plain "UTC".
//                 timesync.cpp parses this into the POSIX TZ string libc wants,
//                 so you never touch POSIX's backwards sign convention yourself.
//                 Whole/half-hour offsets only; no DST (Thailand has none). A
//                 zone with summer time needs a raw POSIX string instead -- e.g.
//                 "EST5EDT,M3.2.0,M11.1.0" -- which this parser passes through
//                 untouched when it sees no "UTC"/"GMT" prefix.
//
// Changing either needs a reflash. Defaults are Asia/Bangkok (UTC+7).
#define WEATHER_TZ "Asia/Bangkok"
#define CLOCK_TZ   "UTC+7"

// Finnhub API token, for the Stock screen. Register a free key at
// finnhub.io/register. It reads public market data and nothing else, so it is a
// soft credential -- but it is still a credential, which is why it sits here
// rather than in config.h. The device sends it directly to Finnhub over TLS
// without validating the certificate (ADR-0004), the same as the other direct
// feeds; on a hostile LAN that exposes the token, and the worst that key can do
// is fetch stock quotes.
#define FINNHUB_TOKEN "your-finnhub-token"
